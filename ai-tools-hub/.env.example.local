# Vercel AI Gateway Configuration (Required for Chat API)
# Get these values by running: vercel env pull
# These use OIDC authentication - never commit raw API keys

AI_GATEWAY_URL=https://gateway.ai.cloudflare.com
AI_GATEWAY_OIDC_TOKEN=your_oidc_token_from_vercel_here

# Local development setup:
# 1. Install Vercel CLI: npm i -g vercel
# 2. Link project: vercel link
# 3. Pull environment: vercel env pull
# 4. This creates .env.local with secrets from Vercel
# 5. npm run dev should now have AI_GATEWAY_OIDC_TOKEN available
