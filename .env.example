# API Keys
# Google Gemini API key for content generation
GEMINI_API_KEY=your-gemini-api-key

# Pexels API key for stock video footage
PEXELS_API_KEY=your-pexels-api-key

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# YouTube API (for Shorts uploads)
# Get these from Google Cloud Console: https://console.cloud.google.com
YOUTUBE_API_KEY=your-youtube-api-key
YOUTUBE_CLIENT_ID=your-oauth-client-id
YOUTUBE_CLIENT_SECRET=your-oauth-client-secret
YOUTUBE_REFRESH_TOKEN=your-oauth-refresh-token

# Make.com Webhooks (Pinterest posting — per brand)
MAKE_WEBHOOK_FITNESS=https://hook.us2.make.com/your-fitness-webhook
MAKE_WEBHOOK_DEALS=https://hook.us2.make.com/your-deals-webhook
MAKE_WEBHOOK_MENOPAUSE=https://hook.us2.make.com/your-menopause-webhook

# Make.com Webhooks (TikTok posting — Make.com scenario 3963775)
# Create 3 routes in the "TikTok Video Automation" scenario (one per brand)
MAKE_WEBHOOK_TIKTOK_FITNESS=https://hook.us2.make.com/your-tiktok-fitness-webhook
MAKE_WEBHOOK_TIKTOK_DEALS=https://hook.us2.make.com/your-tiktok-deals-webhook
MAKE_WEBHOOK_TIKTOK_MENOPAUSE=https://hook.us2.make.com/your-tiktok-menopause-webhook

# Brand Configuration
# Default brand to use when not specified
DEFAULT_BRAND=menopause

# Output Settings
# Maximum cache size in GB (default: 5)
MAX_CACHE_SIZE_GB=5

# Enable verbose logging (true/false)
DEBUG=false
